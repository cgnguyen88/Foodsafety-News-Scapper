{
  "outputDirectory": "dashboard-new/dist",
  "buildCommand": "cd dashboard-new && npm install && npm run build && cp -r ../dashboard dist/dashboard",
  "framework": null,
  "functions": {
    "api/chat.js": {
      "runtime": "nodejs18.x"
    }
  },
  "routes": [
    { "src": "/api/(.*)", "dest": "/api/$1" },
    { "src": "/dashboard/(.*)", "dest": "/dashboard/$1" },
    { "src": "/(.*)", "dest": "/$1" }
  ]
}
